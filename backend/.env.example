APP_NAME=HeartGuard AI
API_PREFIX=/api/v1
MONGODB_URL=mongodb://localhost:27017/heart-disease
STORAGE_DIR=./storage
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_VISION_MODEL=qwen2.5vl:latest
GOOGLE_PLACES_API_KEY=
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
RISK_MODEL_PATH=./ml/models/heart_risk_model.joblib
JWT_SECRET=changeme_use_a_long_random_string_in_production
GEMINI_API_KEYS=your_primary_key,optional_backup_key
